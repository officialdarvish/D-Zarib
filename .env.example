# Docker image name. Docker Hub image names must be lowercase.
IMAGE_NAME=darvish021/d-zarib:latest
CONTAINER_NAME=xui-factor

# serve = webhook mode for 3x-ui External Traffic Inform
# run   = polling mode
# once  = one polling tick then exit
RUN_MODE=serve

# sqlite or postgres
DB_TYPE=sqlite

# SQLite mode: host path of 3x-ui config/db directory.
# The container will see the DB as /etc/x-ui/x-ui.db.
XUI_ETC_DIR=/etc/x-ui
SQLITE_PATH=/etc/x-ui/x-ui.db

# PostgreSQL mode example:
# DB_TYPE=postgres
# POSTGRES_DSN=postgresql://xui_user:xui_password@postgres:5432/xui_db
POSTGRES_DSN=

# Webhook server inside the container.
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=19090
WEBHOOK_PATH=/xui-factor/hook
WEBHOOK_TOKEN=change-this-token
WEBHOOK_LISTEN_IP=127.0.0.1

# Traffic factor behavior
POLL_INTERVAL_SECONDS=3
POLLING_BILLING_ENABLED=false
STRICT_SINGLE_INBOUND=true
ALLOW_MULTI_INBOUND_BEST_EFFORT=false
ACTIVE_INBOUND_STRICT=true
CHARGE_DIRECTION=proportional
LOG_LEVEL=info
